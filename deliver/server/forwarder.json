{
  "_comment": "对等中继 v3 + MySQL。password 为空时本机 root 常会 Access denied；开发可 export FORWARDER_MYSQL_PASSWORD 后 ./scripts/run_dev.sh，详见根 README.md。",
  "client": {
    "listen": { "host": "0.0.0.0", "port": 19000, "backlog": 1024 }
  },
  "admin": {
    "listen": { "host": "127.0.0.1", "port": 19003, "backlog": 128 },
    "events_max": 200
  },
  "threads": { "io": 2, "biz": 2 },
  "timeouts": { "read_ms": 120000, "idle_ms": 600000 },
  "limits": { "max_body_len": 67108864 },
  "metrics": { "interval_ms": 3600000 },
  "flow": {
    "send_queue": { "high_water_bytes": 67108864, "hard_limit_bytes": 268435456, "on_high_water": "drop" }
  },
  "session": {
    "max_connections_per_user": 8,
    "heartbeat_timeout_ms": 30000,
    "broadcast_max_recipients": 10000
  },
  "mysql": {
    "host": "127.0.0.1",
    "port": 3306,
    "user": "root",
    "password": "e2etest",
    "database": "forwarder_e2e"
  }
}
