{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "WSL_Build_All_CPP",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}/*.cpp",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-std=c++20"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "仅适合无外部依赖的单目录练习；本仓库请用 CMake 任务"
        },
        {
            "label": "CMake: build all",
            "type": "shell",
            "command": "cmake --build build -j || (cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build -j)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "asio-forwarder：编服务端、SDK、test_admin（推荐 Ctrl+Shift+B）"
        },
        {
            "label": "CMake: build test_admin",
            "type": "shell",
            "command": "cmake --build build --target test_admin -j || (cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build --target test_admin -j)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "asio-forwarder：仅编 test_admin（含 SDK）"
        },
        {
            "label": "CMake: build test_user",
            "type": "shell",
            "command": "cmake --build build --target test_user -j || (cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build --target test_user -j)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "asio-forwarder：仅编 test_user（含 SDK）"
        }
    ]
}
